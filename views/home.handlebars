<!-- JavaScript for the new SPA mode -->
<script src="/js/plotly-2.29.1.min.js" charset="utf-8"></script>
<script>
  let currentCardID;
  let currentCardStatTime;
  let defaultAction = () => {
    alert('missing default action');
  }

  // mode is /next or /studyNow (these used to be paths)
  function clickStudy (mode) {
    if (mode === '/next') {
      // There may be a card available for study now: only the server knows
      // Query the server and, if there is a card available, display it
      fetch('/next')
      .then(response => {
        response.json()
        .then(data => {
          if(data.cardID) {
            // Load the card front in #front and display that section
            loadCardFront(data.cardID);
            displaySection('front');
          } else {
            loadHome();
            displaySection('home');
          }
        });
      });
    } else if (mode === '/studyNow') {
      fetch('/studyNow')
      .then(response => {
        response.json()
        .then(data => {
          if(data.cardID) {
            // Load the card front in #front and display that section
            alert('clickStudy got a card');
            loadCardFront(data.cardID);
            displaySection('front');
          } else {
            // Update #home and display it
            alert('clickStudy didn not get a card');
            displaySection('home');
          }
        });
      });
    } else {
      alert('invalid mode in call to clickStudy');
    }
  }

  function clickStop () {
    loadHome();
    displaySection('home');
  }

  function clickHome () {
    loadHome();
    displaySection('home');
  }

  function clickFlip () {
    loadCardBack(currentCardID);
    displaySection('back');
  }

  function loadHome () {
    // Load current data to the home section
    fetch('/homeData')
    .then(response => {
      response.json()
      .then(data => {
        console.log('home data: ', data);
        document.getElementById('home_time_to_earliest_due_card')
          .textContent = data.timeToNextDue;
        document.getElementById('home_average_latency')
          .textContent = data.averageLatency;
        document.getElementById('home_due')
          .textContent = data.dueNow;
        document.getElementById('home_overdue')
          .textContent = data.overdue;
        document.getElementById('home_percentCorrect')
          .textContent = data.percentCorrect;
        document.getElementById('home_averageNewCards')
          .textContent = data.averageNewCards;
        document.getElementById('home_newCardsSeen')
          .textContent = data.newCardsSeen;
        document.getElementById('home_averageStudyTime')
          .textContent = data.averageStudyTime;
        document.getElementById('home_studyTime')
          .textContent = data.studyTime;
        document.getElementById('home_statsNext24Hours.count')
          .textContent = data.statsNext24Hours.count;
        document.getElementById('home_statsNext24Hours.time')
          .textContent = data.statsNext24Hours.time;
        document.getElementById('home_statsPast24Hours.count')
          .textContent = data.statsPast24Hours.count;
        document.getElementById('home_statsPast24Hours.time')
          .textContent = data.statsPast24Hours.time;
        setSignal(data);

        // Update chart
        let chart1 = document.getElementById('home_chart1');
        const reviewTime = data.chartStudyTime.reviewTime;
        const newTime = data.chartStudyTime.newTime;
        reviewTime.type = 'bar';
        reviewTime.name = 'review';
        reviewTime.hovertemplate = '%{y}<extra></extra>';
        newTime.type = 'bar';
        newTime.name = 'new';
        newTime.hovertemplate = '%{y}<extra></extra>';
        Plotly.newPlot(chart1,
          [ reviewTime, newTime ], {
            barmode: 'stack',
            autosize: true,
            margin: {
              t: 20,
              b: 35,
              l: 40,
              r: 10
            },
            xaxis: { title: 'hour' },
            yaxis: { title: 'minutes' },
            legend: {
              orientation: 'h',
              x: 0.2,
              xanchor: 'left',
              y: 1.15,
            }
          }
        );
      });
    });
  }

  function setSignal (data) {
    document.getElementById('signal_img')
      .src = '/img/' + data.theme + '-' + data.mode + '.png';
    document.getElementById('signal_dueNow')
      .textContent = data.dueNow;
    document.getElementById('signal_statsNext24Hours.reviewsToNextNew')
      .textContent = data.statsNext24Hours.reviewsToNextNew;
    document.getElementById('signal_statsNext24Hours.time')
      .textContent = data.statsNext24Hours.time;
    document.getElementById('signal_statsPast24Hours.time')
      .textContent = data.statsPast24Hours.time;
    document.getElementById('signal_statsPast24Hours.newCards')
      .textContent = data.statsPast24Hours.newCards;
  }

  function loadCardFront (cardID) {
    fetch('/card/' + cardID + '/front')
    .then(response => {
      response.json()
      .then(data => {
        console.log('front data: ', data);
        document.getElementById('template_style')
          .textContent = data.template.css;
        document.getElementById('front_face')
          .textContent = data.front;
        document.getElementById('front_lastinterval')
          .textContent = data.card.lastinterval;
        document.getElementById('front_interval')
          .textContent = data.card.interval;
        document.getElementById('front_timeSinceLastReview')
          .textContent = data.card.timeSinceLastReview;
        document.getElementById('front_factor')
          .textContent = data.card.factor;
        setSignal(data);
        currentCardID = data.card.id;
        currentCardStartTime = data.cardStartTime;
      });
    });
  }

  function loadCardBack (cardID) {
    fetch('/card/' + currentCardID + '/back?startTime=' + currentCardStartTime)
    .then(response => {
      response.json()
      .then(data => {
        console.log('back data: ', data);
        document.getElementById('template_style')
          .textContent = data.template.css;
        document.getElementById('back_face')
          .innerHTML = data.back;
        document.getElementById('back_lastinterval')
          .textContent = data.card.lastinterval;
        document.getElementById('back_interval')
          .textContent = data.card.interval;
        document.getElementById('back_timeSinceLastReview')
          .textContent = data.timeSinceLastReview;
        document.getElementById('back_factor')
          .textContent = data.card.factor;
        document.getElementById('back_intervals.fail')
          .textContent = data.intervals.fail;
        document.getElementById('back_intervals.hard')
          .textContent = data.intervals.hard;
        document.getElementById('back_intervals.good')
          .textContent = data.intervals.good;
        document.getElementById('back_intervals.easy')
          .textContent = data.intervals.easy;
        setSignal(data);

        const cardHistory = document.getElementById('cardHistory');
        if (cardHistory) {
          const chartData = [
            data.chartData.cardFactor,
            data.chartData.cardInterval,
          ];
          chartData[0].mode = 'lines';
          chartData[0].name = 'Factor';
          chartData[0].line = {
            color: 'rgb(185, 213, 232)',
            shape: 'hv'
          };
          chartData[1].mode = 'lines';
          chartData[1].name = 'Interval';
          chartData[1].yaxis = 'y2';
          chartData[1].line = {
            color: 'rgb(31, 119, 180)',
            shape: 'hv'
          };
          let maxInterval = 0;
          for (let i = chartData[0].y.length; i > 0; i--) {
            if (chartData[0].y[i] > maxInterval) maxInterval = chartData[0].y[i];
          }
          let maxFactor = 0;
          console.log('chart 1: ', chartData[1].y);
          for (let i = chartData[1].y.length; i > 0; i--) {
            if (chartData[1].y[i] > maxFactor) maxFactor = chartData[1].y[i];
          }
          console.log('maxInterval: ', maxInterval);
          console.log('maxFactor: ', maxFactor);
          Plotly.newPlot(cardHistory,
            chartData, {
              autosize: true,
              margin: {
                t: 10,
                b: 10,
                l: 30,
                r: 10,
              },
              xaxis: { title: 'datetime', automargin: true },
              yaxis: {
                title: 'factor',
                // range: [ 0, maxFactor ],
                automargin: true,
                rangemode: 'tozero'
              },
              yaxis2: {
                title: 'interval (days)',
                // range: [ 0, maxInterval ],
                overlaying: 'y',
                side: 'right',
                automargin: true,
                rangemode: 'tozero'
              },
            }
          );
        }
      });
    });
  }

  function review (ease) {
    console.log('review ', ease);
    fetch('/card/' + currentCardID + '/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        elapsed: 20,
        ease: ease,
        startTime: currentCardStartTime,
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error(response.url + ': ' + response.status + ': ' +
          response.statusText);
      }
      response.json()
      .then((data) => {
        console.log('response to review: ', data);
        if (data.nextCardID) {
          loadCardFront(data.nextCardID);
          displaySection('front');
        } else {
          clickHome();
        }
      });
    })
    .catch(err => {
      console.log('err: ', err);
      alert(err);
      clickHome();
    });
  }

  function displaySection (section) {
    const sections = document.getElementsByTagName('section')
    for (const e of sections) {
      if (e.id !== section) {
        e.classList.add('hidden');
      }
    }
    if (section === 'home') {
      document.getElementById('home').classList.remove('hidden');
      document.getElementById('signal').classList.remove('hidden');
      defaultAction = () => {
        clickStudy('/next');
      };
    } else if (section === 'front') {
      document.getElementById('signal').classList.remove('hidden');
      document.getElementById('front').classList.remove('hidden');
      defaultAction = clickFlip;
    } else if (section === 'back') {
      document.getElementById('signal').classList.remove('hidden');
      document.getElementById('back').classList.remove('hidden');
      defaultAction = clickFlip;
    } else {
      document.getElementById('signal').classList.add('hidden');
      document.getElementById(section).classList.remove('hidden');
      defaultAction = () => {
        alert('no default action set');
      }
    }
  }

  window.onload = (event) => {
    clickHome();
  };
</script>
