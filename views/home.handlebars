  function review (ease) {
    console.log('review ', ease);
    fetch('/card/' + currentCardID + '/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        elapsed: 20,
        ease: ease,
        startTime: currentCardStartTime,
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error(response.url + ': ' + response.status + ': ' +
          response.statusText);
      }
      response.json()
      .then((data) => {
        console.log('response to review: ', data);
        if (data.nextCardID) {
          loadCardFront(data.nextCardID);
        } else {
          clickHome();
        }
      });
    })
    .catch(err => {
      console.log('err: ', err);
      alert(err);
      clickHome();
    });
  }

  function displaySection (section) {
    currentSection = section;
    const sections = document.getElementsByTagName('section')
    for (const e of sections) {
      if (e.id !== section) {
        e.classList.add('hidden');
      }
    }
    console.log('expose section: ' + section);
    document.getElementById(section).classList.remove('hidden');
    return;

    /*
      document.getElementById('signal').classList.add('hidden');
      defaultAction = () => {
        alert('no default action set');
      }
    */
  }

  function setupAudio (face) {
    console.log('setupAudio ' + face);
    // The DOM is stupid: getElementsByTagName doesn't return an array
    // of elements. Instead, it returns an HTMLCollection, which is an
    // "array-like object" which is not like an array. So, one has to
    // do stupid shit like the following to iterate over the elements.
    let elements = document.querySelectorAll('#' + face + ' audio');
    console.log('elements: ', elements);
    for (let element of elements) {
      console.log('setup one element');
      element.volume = 0.4;
      const files = element.dataset.files.split(',');
      console.log('audio files: ', files);
      element.src = files[0];
      element.pause();
      let i = 0;
      function callback (e) {
        console.log('ended callback function');
        i++;
        if (i < files.length) {
          element.src = files[i];
        } else {
          element.removeEventListener('ended', callback);
        }
      }
      element.addEventListener('ended', callback);
    }
  }

  function playAudio (face) {
    console.log('playAudio ' + face);
    let elements = document.querySelectorAll('#' + face + ' audio');
    console.log('elements: ', elements);
    for (let element of elements) {
      console.log('play one audio element');
      element.play();
    }
  }

