<div id="signal"><img id="signal_img"
src="/img/{{theme}}-{{mode}}.png"></br><div><span id="signal_dueNow"
title="due now">{{dueNow}}</span>/<span
id="signal_statsNext24Hours.reviewsToNextNew" title="reviews before
next new card">{{statsNext24Hours.reviewsToNextNew}}</span>/<span
id="signal_statsNext24Hours.time" title="study time next 24
hour">{{statsNext24Hours.time}}</span>/<span
id="signal_statsPast24Hours.time" title="study time past 24
hours">{{statsPast24Hours.time}}</span>/<span
id="signal_statsPast24Hours.newCards" title="new cards past 24 hours">{{statsPast24Hours.newCards}}</span></div></div>

<section id="home" class="hidden">
<style>
  thead th {
    text-align: right;
  }
  tbody th {
    text-align: left;
  }
  tbody td {
    text-align: right;
  }
</style>
<div class="home {{mode}}">
<h1><img onclick="clickHome()" src="img/logo.png">Spaced Repetition Flashcards</h1>
<table>
<thead>
<tr><th></th><th>Cards</th><th>Minutes</th></tr>
</thead>
<tbody>
<tr><th>Past 24 Hours:</th>
<td><span
  id="home_statsPast24Hours.count"
  title="Cards reviewed (not reviews) in the past 24 hours">{{statsPast24Hours.count}}</span></td>
<td><span
  id="home_statsPast24Hours.time"
  title="Actual study time in the past 24 hours">{{statsPast24Hours.time}}</tr>

<tr><th>Next 24 Hours:</th>
<td><span
  id="home_statsNext24Hours.count"
  title="Estimated Cards to review in the next 24 hours">{{statsNext24Hours.count}}</span></td>
<td><span
  id="home_statsNext24Hours.time"
  title="Estimated study time in the next 24 hours">{{statsNext24Hours.time}}</span></tr>

<tr><th>Study Time Per Day:</th>
<td colspan=2><span
  id="home_averageStudyTime"
  title="short term historic average">{{averageStudyTime}}</span> / <span
  id="home_studyTime"
  title="forward looking average for new card mode">{{studyTime}}</span></td></tr>

<tr><th>New Cards Per Day:</th>
<td colspan=2><span
  id="home_averageNewCards"
  title="short term historic average">{{averageNewCards}}</span> / <span
  id="home_newCardsSeen"
  title="past 24 hours">{{newCardsSeen}}</span></td></tr>

<tr><th>Percent correct:</th>
<td colspan=2><span id="home_percentCorrect">{{percentCorrect}}</span>%</td></tr>

<tr><th>Cards due:</th><td colspan=2><span id="home_due"
title="due">{{dueNow}}</span> / <span id="home_overdue" title="overdue">{{overdue}}</span></td></tr>

<tr><th>Time to earliest due card:</th>
<td colspan=2><span
 id="home_time_to_earliest_due_card"
 title="Time to earliest due card (hh:mm:ss)">{{timeToNextDue}}</span> / <span
 id="home_average_latency"
 title="Average latency">{{averageLatency}}</span></td></tr>
</tbody>
</table>
<button id="study" class="shortcut_s" onclick="clickStudy('/next')">Study</button>
<button id="reload" onclick="clickHome()">Reload</button>
<h3>Study time per hour</h3>
<div id="home_chart1" class="chart"></div>
<div class="buttons">
<button onclick="window.location.replace('/admin')">Admin</button>
&nbsp;
<button id="button_stats" onclick="window.location.replace('/stats')">Stats</button>
&nbsp;
<a href="/help" target="_blank"><button>Help</button></a>
</div>
</div>
</section>

<!-- This style is for front and back -->
<style id="template_style">
</style>

<section id="front" class="hidden">
  <div id="front_content">
  <h1>Front</h1>
  <div id="front_face" class="card">
  {{{front}}}
  </div>
  <div class="buttons">
  <span id="card-metrics">
  (<span id="front_lastinterval" title="original interval">{{card.lastinterval}}</span>
  <span id="front_interval" title="adjusted interval">{{card.interval}}</span>
  <span id="front_timeSinceLastReview" title="time since last review">{{timeSinceLastReview}}</span>
  <span id="front_factor" title="card factor">{{card.factor}}</span>)
  </span>

  <button onclick="clickFlip()">Flip</button>
  <a href="/help" target="_blank"><button>Help</button></a>
  <a onclick="window.open('/fieldset/{{card.fieldsetid}}', 'Edit Fieldset', 'height=800,width=600');" class="shortcut_e" target="_blank"><button>Edit</button></a>
  <button onclick="replay()" class="shortcut_p">Play</button>
  <button class="shortcut_s" onclick="clickStop()">Stop</button>
  </div>
  </div>
</section>

<section id="back" class="hidden">
  <h1>Back</h1>
  <div id="back_face" class="card">
  {{{back}}}
  </div>
  <div class="buttons">
  <span id="card-metrics">
  (<span id="back_lastinterval" title="original interval">{{card.lastinterval}}</span>
  <span id="back_interval" title="adjusted interval">{{card.interval}}</span>
  <span id="back_timeSinceLastReview" title="time since last review">{{timeSinceLastReview}}</span>
  <span id="back_factor" title="card factor">{{card.factor}}</span>)
  </span>
  </span>
  <button onclick="review('fail')" class="shortcut_j">Fail (<span
  id="back_intervals.fail">{{intervals.fail}}</span>)</button>
  <button onclick="review('hard')" class="shortcut_k">Hard (<span
  id="back_intervals.hard">{{intervals.hard}}</span>)</button>
  <button onclick="review('good')" class="shortcut_l">Good (<span
  id="back_intervals.good">{{intervals.good}}</span>)</button>
  <button onclick="review('easy')" class="shortcut_semicolon">Easy (<span
  id="back_intervals.easy">{{intervals.easy}}</span>)</button>
  <a href="/help" target="_blank"><button>Help</button></a>
  <a onclick="window.open('/fieldset/{{card.fieldsetid}}', 'Edit Fieldset', 'height=800,width=600');" class="shortcut_e" target="_blank"><button>Edit</button></a>
  <button onclick="replay()" class="shortcut_p">Play</button>
